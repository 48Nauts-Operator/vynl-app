# ── Music Library ──────────────────────────────────────────────────────
# Path to your music on the host (NAS mount or local directory)
MUSIC_LIBRARY_PATH=/Volumes/Music
BEETS_DB_PATH=/Volumes/Music/library.db

# Path remap: if beets DB has old paths, remap them
# Format: old_prefix::new_prefix
BEETS_PATH_REMAP=

# Podcast episode storage
PODCAST_STORAGE_PATH=/Volumes/Music/podcasts

# ── Networking ────────────────────────────────────────────────────────
# Your machine's LAN IP (required for Sonos to stream audio back)
# Do NOT use localhost — Sonos speakers need a reachable IP
VYNL_HOST=http://192.168.1.100:3101
NEXT_PUBLIC_VYNL_HOST=http://192.168.1.100:3101

# For Docker: your host machine's IP
HOST_IP=192.168.1.100

# ── API Keys ──────────────────────────────────────────────────────────
# Anthropic (required for AI Discovery & Recommendations)
ANTHROPIC_API_KEY=

# Spotify (optional — for Spotify playback integration + library extract)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Must use 127.0.0.1 (not localhost) — Spotify requires explicit loopback IP
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3101/api/spotify/callback

# Replicate (optional — for AI cover art generation)
REPLICATE_API_TOKEN=

# YouTube (optional — for future YouTube integration)
YOUTUBE_API_KEY=

# ── Sonos ─────────────────────────────────────────────────────────────
# Vynl auto-discovers Sonos speakers on the LAN via SSDP. This usually
# requires the container to run with network_mode: host (see docker-compose.yml).
# If discovery returns nothing — e.g. multicast blocked between VLANs, or
# a bridge-network deployment — set this to the IP of any one Sonos speaker.
# The rest of the household will be discovered via Sonos topology.
SONOS_SEED_IP=

# ── GitHub Stats ──────────────────────────────────────────────────────
# Optional. Powers the /github-stats page. Without it, you still get
# stars + release downloads (public endpoints), but Traffic (views/clones)
# stays hidden because that endpoint requires auth.
# Fine-grained PAT scopes needed on 48Nauts-Operator/vynl-app:
#   Metadata: Read-only
#   Administration: Read-only  (this is what unlocks the Traffic API)
GH_STATS_PAT=

# ── Beets Config (Docker only) ───────────────────────────────────────
# Path to your beets config on the host (mounted into container)
BEETS_CONFIG=./beets-config.yaml
